{
  "redirects": [
    {
      "source": "/streamsync",
      "destination": "/streamsync/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/streamsync/",
      "destination": "/Latest_portfolio/files/index.html"
    },
    {
      "source": "/streamsync/:path*",
      "destination": "/Latest_portfolio/files/:path*"
    }
  ]
}
