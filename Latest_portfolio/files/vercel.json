{
  "rewrites": [
    {
      "source": "/streamsync/:path*",
      "destination": "https://streamsync-blue.vercel.app/:path*"
    },
    {
      "source": "/leetcode(.*)",
      "destination": "https://leetcode-dashboard-five.vercel.app/leetcode$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}